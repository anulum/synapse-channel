{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "description": "The Prometheus instance scraping the hub's /metrics."
    }
  ],
  "uid": "synapse-hub",
  "title": "SYNAPSE Channel \u2014 Hub",
  "description": "The hub deciding, not just existing: liveness, decision rates, refusals, and the dead-letter ledger, all from `synapse hub --metrics`. Log-derived analytics (causality, reliability) live in the dashboard's store feeds and the cockpit, not here.",
  "tags": [
    "synapse",
    "coordination"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Hub up",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "synapse_up",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Online agents",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "synapse_online_agents",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Live waiters",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "synapse_live_waiters",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active claims",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "synapse_active_claims",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Board tasks",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "synapse_blackboard_tasks",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Dead-letter targets",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "synapse_dead_letter_targets",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Connections",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "synapse_connected_clients",
          "legendFormat": "connected sockets",
          "refId": "A"
        },
        {
          "expr": "synapse_online_agents",
          "legendFormat": "named agents",
          "refId": "B"
        },
        {
          "expr": "synapse_live_waiters",
          "legendFormat": "-rx waiters",
          "refId": "C"
        }
      ]
    },
    {
      "id": 11,
      "title": "Message rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "rate(synapse_messages_total[5m])",
          "legendFormat": "all frames/s",
          "refId": "A"
        },
        {
          "expr": "rate(synapse_chat_directed_total[5m])",
          "legendFormat": "directed chat/s",
          "refId": "B"
        },
        {
          "expr": "rate(synapse_chat_broadcast_total[5m])",
          "legendFormat": "broadcast chat/s",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "title": "Claim decisions",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "rate(synapse_claims_granted_total[5m])",
          "legendFormat": "granted/s",
          "refId": "A"
        },
        {
          "expr": "rate(synapse_claims_denied_total[5m])",
          "legendFormat": "denied/s",
          "refId": "B"
        },
        {
          "expr": "rate(synapse_releases_granted_total[5m])",
          "legendFormat": "released/s",
          "refId": "C"
        }
      ]
    },
    {
      "id": 13,
      "title": "Refusals",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "increase(synapse_auth_failures_total[5m])",
          "legendFormat": "auth failures",
          "refId": "A"
        },
        {
          "expr": "increase(synapse_rate_limited_total[5m])",
          "legendFormat": "rate limited",
          "refId": "B"
        },
        {
          "expr": "increase(synapse_federation_denied_total[5m])",
          "legendFormat": "federation denied",
          "refId": "C"
        }
      ]
    },
    {
      "id": 14,
      "title": "Dead letters",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "synapse_dead_letters",
          "legendFormat": "letters (all targets)",
          "refId": "A"
        },
        {
          "expr": "synapse_dead_letter_targets",
          "legendFormat": "targets",
          "refId": "B"
        }
      ]
    },
    {
      "id": 15,
      "title": "Waiter takeovers",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "increase(synapse_takeovers_total[15m])",
          "legendFormat": "takeovers (15m)",
          "refId": "A"
        },
        {
          "expr": "increase(synapse_takeover_quarantines_total[15m])",
          "legendFormat": "quarantines (15m)",
          "refId": "B"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}
