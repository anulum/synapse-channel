{
  "name": "@anulum/synapse-channel",
  "version": "0.1.0",
  "description": "Official typed TypeScript/JavaScript WebSocket client for the SYNAPSE CHANNEL coordination hub: chat, claims, releases, board, presence, and receipts.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "synapse",
    "coordination",
    "multi-agent",
    "websocket",
    "client"
  ],
  "author": "Anulum Fortis & Arcane Sapience <protoscience@anulum.li>",
  "repository": {
    "type": "git",
    "url": "https://github.com/anulum/synapse-channel",
    "directory": "clients/js"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
