{
  "name": "synapse-channel-vscode",
  "private": true,
  "displayName": "SYNAPSE CHANNEL",
  "description": "Claim files, release them, watch the board, and see hub health from inside VS Code or Cursor.",
  "version": "0.2.0",
  "license": "AGPL-3.0-or-later",
  "publisher": "anulum",
  "repository": {
    "type": "git",
    "url": "https://github.com/anulum/synapse-channel.git",
    "directory": "clients/vscode"
  },
  "homepage": "https://github.com/anulum/synapse-channel/tree/main/clients/vscode#readme",
  "bugs": {
    "url": "https://github.com/anulum/synapse-channel/issues"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": ["SCM Providers", "Other"],
  "main": "./out/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      { "command": "synapse.claimFile", "title": "SYNAPSE: Claim current file" },
      { "command": "synapse.releaseFile", "title": "SYNAPSE: Release current file" },
      { "command": "synapse.showBoard", "title": "SYNAPSE: Show board" },
      { "command": "synapse.refreshHealth", "title": "SYNAPSE: Refresh hub health" },
      { "command": "synapse.setHubToken", "title": "SYNAPSE: Set hub token" },
      { "command": "synapse.clearHubToken", "title": "SYNAPSE: Clear hub token" }
    ],
    "views": {
      "explorer": [{ "id": "synapseBoard", "name": "SYNAPSE board" }]
    },
    "configuration": {
      "title": "SYNAPSE CHANNEL",
      "properties": {
        "synapse.hubUri": {
          "type": "string",
          "default": "ws://127.0.0.1:8876",
          "description": "WebSocket URI of the SYNAPSE hub. Remote hubs require wss://."
        },
        "synapse.identity": {
          "type": "string",
          "default": "",
          "description": "Agent identity to register as; empty derives one from the workspace."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:integration": "tsc -p tsconfig.integration.json",
    "vscode:prepublish": "npm run build",
    "prepackage:vsix": "node -e \"require('node:fs').mkdirSync('dist',{recursive:true})\"",
    "package:vsix": "vsce package --no-dependencies --out dist/synapse-channel-vscode.vsix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "npm run build && npm run build:integration && node dist/integration/launch.cjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.9.2",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
